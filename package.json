{
  "name": "codebase-gardener",
  "version": "0.1.0",
  "description": "Local-first CLI that detects low-risk maintenance work and opens small, reviewable fix PRs — like Dependabot, but for codebase upkeep.",
  "license": "MIT",
  "bin": {
    "codebase-gardener": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.1",
    "commander": "^12.1.0",
    "cross-spawn": "^7.0.6",
    "yaml": "^2.6.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
