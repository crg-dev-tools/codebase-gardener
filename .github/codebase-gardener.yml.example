# codebase-gardener configuration (all fields optional; safe defaults apply when omitted)
enabled: true

# safe | (future: aggressive) — only "safe" is honored in the MVP
mode: safe

# Minimum model confidence (0..1) for a candidate to be acted on in `run`.
min_confidence: 0.6

# Max scan chunks (model calls) for a large repo. Files are split into
# size-bounded chunks so the whole repo is covered; this caps the calls.
max_scan_chunks: 8

limits:
  max_files_per_pr: 5
  max_changed_lines_per_pr: 200
  max_prs_per_run: 1

# Which low-risk rules the scanner is allowed to consider.
rules:
  - lint_fix
  - unused_import
  - unused_variable
  - remove_debugger
  - deprecated_api
  - type_narrowing
  - small_test_addition
  - typo
  - stale_docs

exclude:
  - "node_modules/**"
  - "dist/**"
  - "build/**"
  - "coverage/**"
  - "vendor/**"
  - "migrations/**"
  - "**/*.min.js"

pr:
  draft: true
  branch_prefix: "gardener/"
  labels:
    - "maintenance"
    - "ai-generated"
