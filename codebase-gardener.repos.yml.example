# Registry of repositories for `codebase-gardener batch`.
# Repo paths are resolved relative to THIS file. Per-repo fields override the
# batch command's defaults (which come from its CLI flags).
repos:
  - path: ../my-app

  - path: ../another-service
    rules: [typo, unused_import]
    create_pr: true
    max_prs: 2

  - path: /absolute/path/to/repo
    dry_run: true
